{
  "openapi": "3.0.3",
  "info": {
    "title": "Awesome Pizza API",
    "description": "REST API for the Awesome Pizza ordering application. Allows clients to browse the daily menu, place orders, look up orders, and manage order status transitions.\n\n**Order Status Flow:**\n```\nRECEIVED → DELIVERING → DELIVERED\nRECEIVED → CANCELED\n```",
    "version": "1.0.0",
    "contact": {
      "name": "Awesome Pizza"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Menu",
      "description": "Daily menu operations"
    },
    {
      "name": "Orders",
      "description": "Order placement and management"
    }
  ],
  "paths": {
    "/api/daily-menu": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get daily menu",
        "description": "Returns the list of pizza items available for today. Always returns exactly 5 items.",
        "operationId": "getDailyMenu",
        "responses": {
          "200": {
            "description": "List of available pizza items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MenuItem"
                      }
                    }
                  }
                },
                "example": {
                  "success": true,
                  "data": [
                    {
                      "id": "pizza-001",
                      "name": "Margherita Pizza",
                      "description": "Classic tomato sauce, mozzarella, and fresh basil.",
                      "image": "/images/margherita.jpg"
                    },
                    {
                      "id": "pizza-002",
                      "name": "Pepperoni Pizza",
                      "description": "Loaded with pepperoni and melted mozzarella.",
                      "image": "/images/pepperoni.jpg"
                    },
                    {
                      "id": "pizza-003",
                      "name": "BBQ Chicken Pizza",
                      "description": "Smoky BBQ sauce, grilled chicken, and red onions.",
                      "image": "/images/bbq-chicken.jpg"
                    },
                    {
                      "id": "pizza-004",
                      "name": "Veggie Supreme",
                      "description": "Bell peppers, mushrooms, olives, and onions.",
                      "image": "/images/veggie.jpg"
                    },
                    {
                      "id": "pizza-005",
                      "name": "Four Cheese Pizza",
                      "description": "Mozzarella, cheddar, gouda, and parmesan.",
                      "image": "/images/four-cheese.jpg"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/orders": {
      "post": {
        "tags": ["Orders"],
        "summary": "Place a new order",
        "description": "Creates a new pizza order. Requires a customer name (`sender`) and at least one item in `contents`.",
        "operationId": "createOrder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              },
              "examples": {
                "single_item": {
                  "summary": "Single item order",
                  "value": {
                    "sender": "Alice",
                    "contents": [
                      { "name": "Pepperoni Pizza", "quantity": 2 }
                    ]
                  }
                },
                "multiple_items": {
                  "summary": "Multiple items order",
                  "value": {
                    "sender": "Bob",
                    "contents": [
                      { "name": "Margherita Pizza", "quantity": 1 },
                      { "name": "BBQ Chicken Pizza", "quantity": 2 }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Order"
                    }
                  }
                },
                "example": {
                  "success": true,
                  "data": {
                    "id": "order-a1b2c3d4",
                    "sender": "Alice",
                    "status": "RECEIVED",
                    "contents": [
                      { "name": "Pepperoni Pizza", "quantity": 2 }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error — missing `sender` or empty/missing `contents`",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missing_sender": {
                    "summary": "Missing sender field",
                    "value": {
                      "success": false,
                      "message": "Field 'sender' is required."
                    }
                  },
                  "empty_contents": {
                    "summary": "Empty contents array",
                    "value": {
                      "success": false,
                      "message": "Field 'contents' must be a non-empty array."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order by ID",
        "description": "Retrieves the details of an existing order including its status and items.",
        "operationId": "getOrder",
        "parameters": [
          {
            "$ref": "#/components/parameters/OrderId"
          }
        ],
        "responses": {
          "200": {
            "description": "Order found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Order"
                    }
                  }
                },
                "example": {
                  "success": true,
                  "data": {
                    "id": "order-a1b2c3d4",
                    "sender": "Alice",
                    "status": "RECEIVED",
                    "contents": [
                      { "name": "Pepperoni Pizza", "quantity": 2 }
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Order not found."
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Orders"],
        "summary": "Update order status",
        "description": "Updates the status of an existing order. Only valid status transitions are accepted.\n\n**Valid transitions:**\n- `RECEIVED` → `DELIVERING`\n- `RECEIVED` → `CANCELED`\n- `DELIVERING` → `DELIVERED`",
        "operationId": "updateOrderStatus",
        "parameters": [
          {
            "$ref": "#/components/parameters/OrderId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrderStatusRequest"
              },
              "examples": {
                "mark_delivering": {
                  "summary": "Mark as Delivering",
                  "value": { "status": "DELIVERING" }
                },
                "mark_delivered": {
                  "summary": "Mark as Delivered",
                  "value": { "status": "DELIVERED" }
                },
                "cancel_order": {
                  "summary": "Cancel Order",
                  "value": { "status": "CANCELED" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Order"
                    }
                  }
                },
                "example": {
                  "success": true,
                  "data": {
                    "id": "order-a1b2c3d4",
                    "sender": "Alice",
                    "status": "DELIVERING",
                    "contents": [
                      { "name": "Pepperoni Pizza", "quantity": 2 }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid status value",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Invalid status. Valid values are: RECEIVED, DELIVERING, DELIVERED, CANCELED."
                }
              }
            }
          },
          "404": {
            "description": "Order not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Order not found."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "OrderId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the order",
        "schema": {
          "type": "string",
          "example": "order-a1b2c3d4"
        }
      }
    },
    "schemas": {
      "MenuItem": {
        "type": "object",
        "required": ["id", "name", "description", "image"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique item identifier",
            "example": "pizza-001"
          },
          "name": {
            "type": "string",
            "description": "Display name of the pizza",
            "example": "Margherita Pizza"
          },
          "description": {
            "type": "string",
            "description": "Short description of the pizza",
            "example": "Classic tomato sauce, mozzarella, and fresh basil."
          },
          "image": {
            "type": "string",
            "description": "URL path to the pizza image",
            "example": "/images/margherita.jpg"
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "required": ["name", "quantity"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the pizza",
            "example": "Pepperoni Pizza"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of this pizza in the order",
            "example": 2
          }
        }
      },
      "Order": {
        "type": "object",
        "required": ["id", "sender", "status", "contents"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique order identifier",
            "example": "order-a1b2c3d4"
          },
          "sender": {
            "type": "string",
            "description": "Customer name who placed the order",
            "example": "Alice"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          },
          "contents": {
            "type": "array",
            "description": "List of pizza items in the order",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          }
        }
      },
      "OrderStatus": {
        "type": "string",
        "description": "Current status of the order",
        "enum": ["RECEIVED", "DELIVERING", "DELIVERED", "CANCELED"],
        "example": "RECEIVED"
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["sender", "contents"],
        "properties": {
          "sender": {
            "type": "string",
            "description": "Customer name placing the order",
            "example": "Alice"
          },
          "contents": {
            "type": "array",
            "description": "List of pizza items to order. Must contain at least one item.",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          }
        }
      },
      "UpdateOrderStatusRequest": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["success", "message"],
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "description": "Human-readable description of the error",
            "example": "Order not found."
          }
        }
      }
    }
  }
}
